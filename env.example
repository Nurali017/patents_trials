# === env/app ===
MODE=prod
DEBUG=0
SECRET_KEY=CHANGE_ME_generate_with_python_c_from_django_core_management_utils_import_get_random_secret_key_print_get_random_secret_key
HOST_NAME=trials.rizeup.kz
ALLOWED_HOSTS=trials.rizeup.kz,trials.dusbase.kz,trials-api,127.0.0.1,localhost
CORS_ALLOWED_ORIGINS=https://trials.rizeup.kz,https://trials.dusbase.kz,https://dusbase.kz

# Database
SQL_ENGINE=django.db.backends.postgresql
SQL_DATABASE=trials_db
SQL_USER=CHANGE_ME
SQL_PASSWORD=CHANGE_ME
SQL_HOST=trials-db
SQL_PORT=5432

# Patents Service integration
# patents-api resolves via shared docker network "patents_shared"
# patents-backend must be deployed first
PATENTS_SERVICE_URL=http://patents-api:8000
PATENTS_SERVICE_USERNAME=CHANGE_ME
PATENTS_SERVICE_PASSWORD=CHANGE_ME

# Gunicorn (optional)
GUNICORN_WORKERS=3
GUNICORN_TIMEOUT=120

# Storage backend
MEDIA_BACKEND=minio
LEGACY_MEDIA_ROOT=/usr/src/app/legacy-media

# Filesystem media root, used when MEDIA_BACKEND=filesystem
TRIALS_MEDIA_HOST_PATH=/root/patents/volumes/media

# Legacy filesystem media root mounted read-only for dual-read fallback
TRIALS_LEGACY_MEDIA_HOST_PATH=/root/patents/volumes/media

# MinIO
MINIO_ENDPOINT=http://minio:9000
MINIO_BUCKET=trials-media
MINIO_REGION=us-east-1
MINIO_ROOT_USER=CHANGE_ME_minio_root
MINIO_ROOT_PASSWORD=CHANGE_ME_minio_root_password
MINIO_ACCESS_KEY=CHANGE_ME_trials_app
MINIO_SECRET_KEY=CHANGE_ME_trials_app_secret
MINIO_PRESIGNED_URL_EXPIRY_SECONDS=600
MINIO_CONSOLE_PORT=9001

# === env/db ===
POSTGRES_USER=CHANGE_ME
POSTGRES_PASSWORD=CHANGE_ME
POSTGRES_DB=trials_db
